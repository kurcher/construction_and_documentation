# ==========================================
# Віртуальні оточення (Virtual Environments)
# ==========================================
venv/
.venv/
env/
.env/

# ==========================================
# Локальні бази даних та сховища (Databases)
# ==========================================
*.db
*.sqlite
*.sqlite3
messenger.db

# ==========================================
# Кеш та скомпільовані файли Python (Byte-compiled)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ==========================================
# Змінні оточення та секрети (Secrets)
# ==========================================
.env
.env.*
!.env.example

# ==========================================
# Налаштування IDE та редакторів (IDEs)
# ==========================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ==========================================
# Логи та звіти (Logs & Reports)
# ==========================================
*.log
.coverage
htmlcov/